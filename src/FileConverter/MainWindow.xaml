<Window x:Class="FileConverter.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:behaviors="clr-namespace:FileConverter.Behaviors"
        xmlns:conv="clr-namespace:FileConverter.Converters"
        xmlns:controls="clr-namespace:FileConverter.Views.Controls"
        Title="File Converter"
        Height="780"
        Width="1160"
        MinHeight="660"
        MinWidth="980"
        WindowStartupLocation="CenterScreen"
        Background="Transparent">

    <Window.Resources>
        <conv:StatusToBrushConverter x:Key="StatusToBrush" />
        <conv:CategoryVisibilityConverter x:Key="CategoryVisibility" />
        <conv:CategoryToIconConverter x:Key="CategoryToIcon" />
        <conv:CategoryToAccentBrushConverter x:Key="CategoryToAccent" />
        <conv:InverseBooleanConverter x:Key="InverseBoolean" />
        <conv:CountToVisibilityConverter x:Key="CountToVisibility" />
        <conv:BoolToVisibilityConverter x:Key="BoolToVisibility" />
        <conv:InverseCountToVisibilityConverter x:Key="InverseCountToVisibility" />
        <conv:AttachedPropertyToVisibilityConverter x:Key="AttachedVisibility" />

        <Style x:Key="DragOverlay" TargetType="Border">
            <Setter Property="Background" Value="{StaticResource DropHighlightBrush}" />
            <Setter Property="BorderBrush" Value="{StaticResource PrimaryBrush}" />
            <Setter Property="BorderThickness" Value="2" />
            <Setter Property="CornerRadius" Value="{StaticResource CardCornerRadius}" />
            <Setter Property="Visibility" Value="Collapsed" />
        </Style>
    </Window.Resources>

    <Grid Margin="32">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!-- Header -->
        <StackPanel Grid.Row="0" Margin="0,0,0,28">
            <TextBlock Text="File Converter"
                       FontSize="34"
                       FontWeight="SemiBold" />
            <TextBlock Text="Convert images, audio, video, and documents"
                       Foreground="{StaticResource TextSecondaryBrush}"
                       FontSize="15"
                       Margin="0,8,0,0" />
        </StackPanel>

        <!-- Settings -->
        <Border Grid.Row="1" Style="{StaticResource CardBorder}" Margin="0,0,0,18" Padding="20">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="20" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <Grid Grid.Row="0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="160" />
                        <ColumnDefinition Width="28" />
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="160" />
                        <ColumnDefinition Width="28" />
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="190" />
                    </Grid.ColumnDefinitions>

                    <TextBlock Grid.Column="0" Text="Category" Style="{StaticResource FieldLabel}" />
                    <ComboBox Grid.Column="1" ItemsSource="{Binding Categories}" SelectedItem="{Binding SelectedCategory}" />

                    <TextBlock Grid.Column="3" Text="Format" Style="{StaticResource FieldLabel}" />
                    <ComboBox Grid.Column="4" ItemsSource="{Binding AvailableFormats}" SelectedItem="{Binding SelectedFormat}" />

                    <TextBlock Grid.Column="6" Text="Operation" Style="{StaticResource FieldLabel}"
                               Visibility="{Binding SelectedCategory, Converter={StaticResource CategoryVisibility}, ConverterParameter=Document}" />
                    <ComboBox Grid.Column="7" ItemsSource="{Binding DocumentOperations}" SelectedItem="{Binding SelectedOperation}"
                              Visibility="{Binding SelectedCategory, Converter={StaticResource CategoryVisibility}, ConverterParameter=Document}" />
                </Grid>

                <Grid Grid.Row="2">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="12" />
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="12" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>

                    <TextBlock Grid.Column="0" Text="Output" Style="{StaticResource FieldLabel}" />
                    <TextBox Grid.Column="1" Text="{Binding OutputDirectory, UpdateSourceTrigger=PropertyChanged}" />

                    <Button Grid.Column="3" Style="{StaticResource SecondaryButton}" Command="{Binding BrowseOutputFolderCommand}">
                        <StackPanel Orientation="Horizontal">
                            <Path Data="{StaticResource IconFolder}" Style="{StaticResource IconPath}" />
                            <TextBlock Text="Browse" Margin="8,0,0,0" VerticalAlignment="Center" />
                        </StackPanel>
                    </Button>

                    <Button Grid.Column="5" Style="{StaticResource SecondaryButton}" Command="{Binding AddFilesCommand}">
                        <StackPanel Orientation="Horizontal">
                            <Path Data="{StaticResource IconAdd}" Style="{StaticResource IconPath}" />
                            <TextBlock Text="Add Files" Margin="8,0,0,0" VerticalAlignment="Center" />
                        </StackPanel>
                    </Button>
                </Grid>
            </Grid>
        </Border>

        <!-- Queue / drop zone -->
        <Border Grid.Row="2"
                Style="{StaticResource CardBorder}"
                Padding="0"
                Margin="0,0,0,4">
            <Grid>
                <!-- Empty state -->
                <Border Style="{StaticResource DropZoneBorder}"
                        Visibility="{Binding Queue.Count, Converter={StaticResource CountToVisibility}}">
                    <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                        <Border Background="{StaticResource SurfaceElevatedBrush}"
                                Width="72" Height="72"
                                CornerRadius="36"
                                Margin="0,0,0,18">
                            <Path Data="{StaticResource IconUpload}"
                                  Style="{StaticResource IconPath}"
                                  Width="32" Height="32"
                                  HorizontalAlignment="Center"
                                  VerticalAlignment="Center"
                                  Opacity="0.85" />
                        </Border>
                        <TextBlock Text="Drag and drop files or folders here"
                                   Foreground="{StaticResource TextPrimaryBrush}"
                                   FontSize="17"
                                   FontWeight="SemiBold"
                                   HorizontalAlignment="Center" />
                        <TextBlock Text="Supported formats appear based on the selected category"
                                   Foreground="{StaticResource TextSecondaryBrush}"
                                   FontSize="13"
                                   HorizontalAlignment="Center"
                                   Margin="0,8,0,0" />
                    </StackPanel>
                </Border>

                <!-- Drag target (covers entire card) -->
                <Border x:Name="DropZone"
                        Background="Transparent"
                        behaviors:DragDropBehavior.IsEnabled="True"
                        behaviors:DragDropBehavior.DropCommand="{Binding DropFilesCommand}" />

                <Border Style="{StaticResource DragOverlay}"
                        IsHitTestVisible="False"
                        Margin="16"
                        Visibility="{Binding (behaviors:DragDropBehavior.IsDragOver), ElementName=DropZone, Converter={StaticResource AttachedVisibility}}" />

                <!-- File list -->
                <ListBox ItemsSource="{Binding Queue}"
                         Margin="16"
                         Visibility="{Binding Queue.Count, Converter={StaticResource InverseCountToVisibility}}">
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <Border Style="{StaticResource QueueItemBorder}">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto" />
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                        <ColumnDefinition Width="Auto" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="Auto" />
                                    </Grid.RowDefinitions>

                                    <!-- File type icon -->
                                    <Border Grid.Row="0" Grid.Column="0" Grid.RowSpan="2"
                                            Width="40" Height="40"
                                            CornerRadius="8"
                                            Margin="0,0,14,0"
                                            VerticalAlignment="Top"
                                            Background="{StaticResource SurfaceBrush}">
                                        <Path Data="{Binding Category, Converter={StaticResource CategoryToIcon}}"
                                              Style="{StaticResource FileTypeIcon}"
                                              Fill="{Binding Category, Converter={StaticResource CategoryToAccent}}"
                                              HorizontalAlignment="Center"
                                              VerticalAlignment="Center" />
                                    </Border>

                                    <!-- File name + path -->
                                    <StackPanel Grid.Row="0" Grid.Column="1" VerticalAlignment="Center">
                                        <TextBlock Text="{Binding FileName}"
                                                   FontWeight="SemiBold"
                                                   FontSize="14"
                                                   TextTrimming="CharacterEllipsis" />
                                        <TextBlock Text="{Binding SourcePath}"
                                                   Foreground="{StaticResource TextSecondaryBrush}"
                                                   FontSize="12"
                                                   TextTrimming="CharacterEllipsis"
                                                   Margin="0,3,0,0" />
                                    </StackPanel>

                                    <!-- Meta: size + format -->
                                    <StackPanel Grid.Row="0" Grid.Column="2"
                                                VerticalAlignment="Center"
                                                Margin="16,0,16,0"
                                                MinWidth="100">
                                        <TextBlock Text="{Binding FileSizeText}"
                                                   Foreground="{StaticResource TextSecondaryBrush}"
                                                   FontSize="12"
                                                   HorizontalAlignment="Right" />
                                        <TextBlock Text="{Binding TargetFormat, StringFormat='→ {0}'}"
                                                   Foreground="{StaticResource AccentBrush}"
                                                   FontSize="12"
                                                   FontWeight="SemiBold"
                                                   HorizontalAlignment="Right"
                                                   Margin="0,2,0,0" />
                                    </StackPanel>

                                    <!-- Status badge -->
                                    <Border Grid.Row="0" Grid.Column="3"
                                            Style="{StaticResource StatusBadge}"
                                            VerticalAlignment="Center">
                                        <TextBlock Text="{Binding StatusText}"
                                                   Foreground="{Binding Status, Converter={StaticResource StatusToBrush}}"
                                                   FontSize="12"
                                                   FontWeight="Medium"
                                                   MaxWidth="130"
                                                   TextTrimming="CharacterEllipsis" />
                                    </Border>

                                    <!-- Remove -->
                                    <Button Grid.Row="0" Grid.Column="4"
                                            Style="{StaticResource IconButton}"
                                            VerticalAlignment="Center"
                                            Command="{Binding DataContext.RemoveItemCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                            CommandParameter="{Binding}"
                                            ToolTip="Remove">
                                        <Path Data="{StaticResource IconClose}" Style="{StaticResource IconPath}" Width="11" Height="11" />
                                    </Button>

                                    <!-- Progress -->
                                    <ProgressBar Grid.Row="2" Grid.Column="0" Grid.ColumnSpan="5"
                                                 Value="{Binding Progress}"
                                                 Maximum="100"
                                                 Margin="0,12,0,0"
                                                 Visibility="{Binding IsActive, Converter={StaticResource BoolToVisibility}}" />
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>
            </Grid>
        </Border>

        <!-- Status -->
        <TextBlock Grid.Row="3"
                   Text="{Binding StatusMessage}"
                   Foreground="{StaticResource TextSecondaryBrush}"
                   FontSize="13"
                   Margin="0,12,0,14" />

        <!-- Actions -->
        <Grid Grid.Row="4">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="12" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="12" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>

            <Button Grid.Column="0"
                    Command="{Binding StartConversionCommand}"
                    IsEnabled="{Binding IsConverting, Converter={StaticResource InverseBoolean}}">
                <StackPanel Orientation="Horizontal">
                    <Path Data="{StaticResource IconPlay}" Style="{StaticResource IconPath}" Fill="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}" />
                    <TextBlock Text="Start Conversion" Margin="8,0,0,0" VerticalAlignment="Center" />
                </StackPanel>
            </Button>

            <Button Grid.Column="2"
                    Style="{StaticResource SecondaryButton}"
                    Command="{Binding CancelConversionCommand}"
                    Visibility="{Binding IsConverting, Converter={StaticResource BoolToVisibility}}">
                <StackPanel Orientation="Horizontal">
                    <Path Data="{StaticResource IconStop}" Style="{StaticResource IconPath}" />
                    <TextBlock Text="Cancel" Margin="8,0,0,0" VerticalAlignment="Center" />
                </StackPanel>
            </Button>

            <Button Grid.Column="4"
                    Content="Clear Completed"
                    Style="{StaticResource SecondaryButton}"
                    Command="{Binding ClearCompletedCommand}" />

            <Button Grid.Column="6"
                    Content="Clear All"
                    Style="{StaticResource DangerButton}"
                    Command="{Binding ClearAllCommand}" />
        </Grid>

        <controls:ToastNotificationHost x:Name="ToastHost"
                                        Grid.RowSpan="5"
                                        Panel.ZIndex="100" />
    </Grid>
</Window>
